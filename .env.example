# Backend configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3001
DATABASE_URL=postgres://en_learner:en_learner@127.0.0.1:5432/en_learner
POSTGRES_HOST_PORT=5433
# For Docker Compose the same credentials are created automatically.
# For Render or any public deploy:
# BACKEND_HOST=0.0.0.0
# PORT=3001
PUBLIC_BACKEND_URL=http://127.0.0.1:3001
# PUBLIC_APP_URL=https://app.example.com
AUTH_SESSION_TTL_HOURS=720
SERVE_FRONTEND=false
# FRONTEND_DIST_DIR=./apps/frontend/dist

# Remote auth providers (configure only the ones you want to enable)
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GITHUB_CLIENT_ID=
# AUTH_GITHUB_CLIENT_SECRET=
# AUTH_MICROSOFT_CLIENT_ID=
# AUTH_MICROSOFT_CLIENT_SECRET=
# AUTH_DISCORD_CLIENT_ID=
# AUTH_DISCORD_CLIENT_SECRET=
# AUTH_APPLE_CLIENT_ID=
# AUTH_APPLE_CLIENT_SECRET=

# Frontend (Vite)
VITE_API_BASE_URL=http://127.0.0.1:3001
# Optional public frontend base used for copied public test links
# VITE_PUBLIC_APP_URL=https://app.example.com

# Desktop runtime (optional)
# EN_LEARNER_FRONTEND_URL=https://app.example.com
# EN_LEARNER_FRONTEND_DIST_DIR=./apps/frontend/dist
# EN_LEARNER_BACKEND_URL=http://127.0.0.1:3001
# EN_LEARNER_SPAWN_BACKEND=true
# EN_LEARNER_BACKEND_EXE=./apps/backend/target/release/en-learner-backend
# EN_LEARNER_PUBLIC_APP_URL=https://app.example.com
# EN_LEARNER_NATIVE_DB_PATH=./desktop.db
# Native desktop storage also persists:
# - connectivity mode (auto/offline/online)
# - guest profile name
# - remote auth session cache

# Logging level: error, warn, info, debug, trace
RUST_LOG=info

# External API base URLs (override for testing/proxying)
DICTIONARY_API_URL=https://api.dictionaryapi.dev/api/v2/entries/en
LINGVA_API_URL=https://lingva.ml/api/v1
